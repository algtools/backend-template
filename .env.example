# Variable names expected by sentry-cli during `pnpm sentry:sourcemaps` (post-deploy).
# Configure these in your Cloudflare Workers build / dashboard (or export them locally);
# sentry-cli reads SENTRY_ORG, SENTRY_PROJECT, and SENTRY_AUTH_TOKEN from the environment.
# Token: Sentry → Settings → Auth Tokens (scopes: project:releases, org:read).
SENTRY_ORG=algenium
SENTRY_PROJECT=backend-template
SENTRY_AUTH_TOKEN=sntrys_YOUR_TOKEN_HERE
